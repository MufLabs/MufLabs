{
    "name": "@muf/ui",
    "version": "0.1.0",
    "description": "MUF Labs Design System",
    "license": "MIT",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -b && vite build",
        "typecheck": "tsc --noEmit",
        "dev": "vite",
        "clean": "rimraf dist .turbo tsconfig.tsbuildinfo"
    },
    "peerDependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "class-variance-authority": "^0.7.1",
        "tailwind-merge": "^3.3.1"
    },
    "devDependencies": {
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^5.0.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.8.3",
        "vite": "^7.0.6"
    }
}